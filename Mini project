function processOrders(orders) {
    let totalRevenue = 0;
    let successfulOrders = 0;
    let processedOrders = 0;

    let skippedInRow = 0;
    let stockFailures = 0;
    let stopMessage = null;

    for (const order of orders) {

        // Skip cancelled or invalid orders
        if (order.status === "cancelled" || order.status === "invalid") {
            skippedInRow++;

            if (skippedInRow >= 3) {
                stopMessage = "System stopped due to critical failure";
                break;
            }

            continue;
        }

        // Skip if stock is unavailable
        if (!order.stockAvailable) {
            skippedInRow++;
            stockFailures++;

            if (skippedInRow >= 3 || stockFailures >= 3) {
                stopMessage = "System stopped due to critical failure";
                break;
            }

            continue;
        }

        // Process valid order
        totalRevenue += order.amount;
        successfulOrders++;
        processedOrders++;

        // Reset skipped counter after successful order
        skippedInRow = 0;
    }

    return {
        totalRevenue,
        successfulOrders,
        processedOrders,
        stopMessage
    };
}

// Example
const orders = [
    { id: 1, status: "valid", stockAvailable: true, amount: 100 },
    { id: 2, status: "cancelled", stockAvailable: true, amount: 200 },
    { id: 3, status: "valid", stockAvailable: false, amount: 300 },
    { id: 4, status: "valid", stockAvailable: true, amount: 150 },
    { id: 5, status: "invalid", stockAvailable: true, amount: 250 }
];

console.log(processOrders(orders));
